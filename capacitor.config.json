{
  "appId": "pt.rjp.study",
  "appName": "RJP Study",
  "webDir": "dist",
  "bundledWebRuntime": false,

  "server": {
    "androidScheme": "https"
  },

  "android": {
    "allowMixedContent": true
  },

  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#08284A",
      "showSpinner": false
    },

    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#08284A"
    }
  }
}
